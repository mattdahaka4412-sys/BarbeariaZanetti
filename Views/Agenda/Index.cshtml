@model BarbeariaZanetti.Web.ViewModels.Agenda.AgendaViewModel

@{
    ViewData["Title"] = "Agenda";

    var hoje = DateTime.Today;

    var ano = Model.AnoSelecionado;
    var mes = Model.MesSelecionado;

    var diasNoMes = DateTime.DaysInMonth(ano, mes);

    var primeiroDia = new DateTime(ano, mes, 1);

    var espacosInicio = (int)primeiroDia.DayOfWeek;

    var mesAnterior = primeiroDia.AddMonths(-1);

    var proximoMes = primeiroDia.AddMonths(1);
}

<div class="page-header">
    <div>
        <h2>Agenda</h2>
        <p>@Model.NomeMes</p>
    </div>

    <div class="d-flex gap-2">
        @if (Model.EhAdministrador)
        {
            <button class="btn-secondary-zanetti" data-bs-toggle="modal" data-bs-target="#modalCliente">
                + Novo Cliente
            </button>
        }

        <button class="btn-primary-zanetti" data-bs-toggle="modal" data-bs-target="#modalAgendamento">
            + Novo Agendamento
        </button>
    </div>
</div>

<div class="agenda-layout">
    <section class="calendar-card">
        <div class="calendar-header">
            <a asp-controller="Agenda"
               asp-action="Index"
               asp-route-mes="@mesAnterior.Month"
               asp-route-ano="@mesAnterior.Year"
               class="calendar-nav"
               title="Mês anterior">
                <i class="bi bi-chevron-left"></i>
            </a>

            <strong>@Model.NomeMes</strong>

            <a asp-controller="Agenda"
               asp-action="Index"
               asp-route-mes="@proximoMes.Month"
               asp-route-ano="@proximoMes.Year"
               class="calendar-nav"
               title="Próximo mês">
                <i class="bi bi-chevron-right"></i>
            </a>
        </div>

        <div class="calendar-weekdays">
            <span>Dom</span>
            <span>Seg</span>
            <span>Ter</span>
            <span>Qua</span>
            <span>Qui</span>
            <span>Sex</span>
            <span>Sáb</span>
        </div>

        <div class="calendar-grid">
            @for (int i = 0; i < espacosInicio; i++)
            {
                <div class="calendar-day empty"></div>
            }

            @for (int dia = 1; dia <= diasNoMes; dia++)
            {
                var classe = dia switch
                {
                    5 => "low",
                    8 => "medium",
                    12 => "high",
                    20 => "full",
                    _ => "free"
                };

                var clientes = dia switch
                {
                    5 => "2",
                    8 => "5",
                    12 => "8",
                    20 => "12",
                    _ => "0"
                };

               <button type="button"
                    class="calendar-day @classe"
                    data-dia="@dia"
                    onclick="selecionarDia(@dia, @mes, @ano)">

                    <span>@dia</span>

                    <div class="day-progress">
                        <div class="day-progress-fill"></div>
                    </div>

                    <small>👥 @clientes</small>

                </button>
            }
        </div>
    </section>

    <section class="day-schedule-card">
        <div class="selected-day-header">
            <div>
                <h3 id="selectedDayName">Dia selecionado</h3>
                <p id="selectedDayDate">@hoje.ToString("dd 'de' MMMM 'de' yyyy")</p>
            </div>

            <span id="dayStatus" class="day-status status-free">Livre</span>
        </div>

        <div class="day-occupation">
            <div class="occupation-info">
                <strong id="occupationText">0% ocupado</strong>
                <span id="clientsText">0 cliente(s) agendado(s)</span>
            </div>

            <div class="occupation-info">
                <span>Tempo disponível</span>
                <strong id="freeTimeText">12h livres</strong>
            </div>

            <div class="occupation-bar">
                <div id="occupationFill" class="occupation-fill free" style="width:0%;"></div>
            </div>
        </div>

        <div id="appointmentList" class="appointment-list">
            <div class="agenda-empty-state">
                <h3>Nenhum agendamento para este dia</h3>
                <p>Clique em <strong>Novo Agendamento</strong> para cadastrar um atendimento.</p>
            </div>
        </div>
    </section>
</div>

@if (Model.EhAdministrador)
{
    <div class="modal fade" id="modalCliente" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content zanetti-modal">
                <form asp-controller="Cliente" asp-action="Criar" method="post">
                    <div class="modal-header">
                        <h5 class="modal-title">Novo Cliente</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Nome</label>
                            <input name="Nome" class="form-control zanetti-input" placeholder="Nome do cliente" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Telefone</label>
                            <input name="Telefone" class="form-control zanetti-input" placeholder="(00) 00000-0000" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Observação</label>
                            <textarea name="Observacao" class="form-control zanetti-input" rows="3" placeholder="Opcional"></textarea>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn-secondary-zanetti" data-bs-dismiss="modal">
                            Cancelar
                        </button>

                        <button type="submit" class="btn-primary-zanetti">
                            Salvar Cliente
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<div class="modal fade" id="modalAgendamento" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content zanetti-modal">
            <form asp-controller="Agenda" asp-action="Criar" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Novo Agendamento</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Cliente</label>

                            <select name="ClienteId" class="form-select zanetti-input" required>
                                <option value="">Selecione um cliente</option>

                                @foreach (var cliente in Model.Clientes)
                                {
                                    <option value="@cliente.Id">@cliente.Nome</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Serviço</label>

                            <select id="servicoSelect" name="ServicoId" class="form-select zanetti-input" required>
                                <option value="">Selecione um serviço</option>

                                @foreach (var servico in Model.Servicos)
                                {
                                    <option value="@servico.Id"
                                            data-valor="@servico.ValorPadrao.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                                        @servico.Nome
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Data</label>
                            <input name="Data" type="date" class="form-control zanetti-input" required />
                        </div>

                        <div class="col-md-3 mb-3">
                            <label class="form-label">Hora Início</label>
                            <input id="dataAgendamento" name="Data" type="date"
                           class="form-control zanetti-input"  required />
                        </div>

                        <div class="col-md-3 mb-3">
                            <label class="form-label">Hora Fim</label>
                            <input name="HoraFim" type="time" class="form-control zanetti-input" required />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Valor</label>
                            <input id="valorCobrado"
                                   name="ValorCobrado"
                                   type="text"
                                   class="form-control zanetti-input"
                                   placeholder="0,00"
                                   required />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Barbeiro</label>
                            <input type="text"
                                   class="form-control zanetti-input"
                                   value="@Model.UsuarioNome"
                                   readonly />
                        </div>

                        <div class="col-12 mb-3">
                            <label class="form-label">Observação</label>
                            <textarea name="Observacao"
                                      class="form-control zanetti-input"
                                      rows="3"
                                      placeholder="Opcional"></textarea>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-secondary-zanetti" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn-primary-zanetti">Salvar Agendamento</button>
                </div>
            </form>
        </div>
    </div>
</div>