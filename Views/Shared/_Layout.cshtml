<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Barbearia Zanetti</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Design System -->
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />

    <!-- Agenda -->
    <link rel="stylesheet" href="~/css/Pages/Agenda/agenda.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Pages/Agenda/calendar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Pages/Agenda/appointments.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Pages/Agenda/modal.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/BarbeariaZanetti.Web.styles.css" asp-append-version="true" />
</head>

<body class="zanetti-body">

    <div class="app-shell">

        <partial name="Components/_Sidebar" />

        <div class="app-main">

            <partial name="Components/_Topbar" />

            <main class="app-content">
                @RenderBody()
            </main>

        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script src="~/js/agenda.js" asp-append-version="true"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>